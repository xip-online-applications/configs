{
  "name": "configs",
  "license": "MIT",
  "engines": {
    "npm": ">=11",
    "node": ">=24"
  },
  "scripts": {
    "commitlint": "commitlint --from=HEAD~1",
    "format:check": "nx format:check --all  --parallel",
    "format:fix": "nx format:write --all --parallel",
    "lint": "nx run-many --target=lint --all --parallel",
    "prepare": "husky"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "prettier": "@xip-online-applications/prettier-config",
  "commitlint": {
    "extends": [
      "./packages/commitlint-config"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@nx/eslint": "22.4.2",
    "@nx/eslint-plugin": "22.4.2",
    "@nx/js": "22.4.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@xip-online-applications/eslint-config": "file:./packages/eslint-config",
    "@xip-online-applications/prettier-config": "file:./packages/prettier-config",
    "eslint": "^8.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lerna": "^9.0.3",
    "nx": "22.4.2",
    "prettier": "^3.8.1",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-prettier": "^5.0.3"
  }
}
